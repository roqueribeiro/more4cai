# =============================================================================
# CAI Orchestrator — variáveis de ambiente
# Copie para .env e preencha. NUNCA commitar .env real.
# =============================================================================

# --- Aplicação ---
APP_TOKEN=dev-changeme-with-strong-random
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- AI Gateway (litellm) ---
# Modelo principal. Formato litellm: "<provider>/<model>"
#
# Cenários comuns:
#
# A) Apenas Anthropic Cloud (default)
#   LLM_MODEL=anthropic/claude-opus-4-7
#   LLM_FALLBACK_MODEL=anthropic/claude-haiku-4-5-20251001
#   ANTHROPIC_API_KEY=sk-ant-...
#   (LLM_API_BASE vazio)
#
# B) LM Studio rodando no host Windows com Qwen 27B local (recomendado pra dados sensíveis — não saem)
#   LLM_MODEL=openai/qwen/qwen3.6-27b
#   LLM_API_BASE=http://host.docker.internal:1234/v1
#   LLM_API_KEY=lm-studio
#   LLM_FALLBACK_MODEL=anthropic/claude-haiku-4-5-20251001    (opcional, cloud fallback)
#   ANTHROPIC_API_KEY=sk-ant-...                               (opcional, p/ fallback)
#
# C) Ollama em container do compose
#   LLM_MODEL=ollama/qwen2.5:32b-instruct-q4_K_M
#   LLM_API_BASE=http://ollama:11434/v1
#   LLM_API_KEY=ollama   (qualquer string)
#
LLM_MODEL=anthropic/claude-opus-4-7
LLM_FALLBACK_MODEL=anthropic/claude-haiku-4-5-20251001
# api_base aplicado quando o modelo é OpenAI-compat local. Vazio = usa default do provider.
LLM_API_BASE=
LLM_API_KEY=

# API keys (somente o que você for usar)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Aliases legados (não são mais lidos pelo gateway, mantidos só por compat)
LLM_LOCAL_BASE_URL=http://ollama:11434/v1
LLM_LOCAL_MODEL=ollama/qwen2.5:32b-instruct-q4_K_M

# --- Persistência ---
# Dev SQLite: sqlite+aiosqlite:///./data/cai.db
# Prod Postgres: postgresql+asyncpg://cai:<senha>@postgres:5432/cai
DATABASE_URL=postgresql+asyncpg://cai:cai-dev-changeme@postgres:5432/cai
POSTGRES_PASSWORD=cai-dev-changeme

# Redis pra fila arq
REDIS_URL=redis://redis:6379/0

# --- Scanners ---
ZAP_BASE_URL=http://zap:8090
ZAP_API_KEY=changeme-zap-api-key
TRIVY_SERVER_URL=http://trivy:4954

# Greenbone (Fase 3, opt-in)
GREENBONE_HOST=
GREENBONE_PORT=9390
GREENBONE_USERNAME=admin
GREENBONE_PASSWORD=

# --- OSINT (Fase 2.5) ---
GITHUB_TOKEN=
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=

# --- DefectDojo export (Fase 5, opt-in) ---
DEFECTDOJO_URL=
DEFECTDOJO_API_KEY=

# --- Phoenix tracing (Fase 4, opt-in) ---
PHOENIX_COLLECTOR_ENDPOINT=

# --- OIDC (stub, opt-in) ---
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=

# --- Compliance gates ---
# LAB_ONLY=true (default): bloqueia hosts em rede privada/loopback/IMDS que nao
#   estejam em TARGET_ALLOWLIST. Default seguro pra dev/lab.
# Em prod regulado: manter LAB_ONLY=true E listar o escopo escrito do engagement
#   em TARGET_ALLOWLIST. Entries aceitam hostname, IP, CIDR ou *.dominio.
# REQUIRE_AUTH_REF=true forca operador a passar `authorization_ref` (ID de ticket
#   ou aprovacao formal) em todo POST /scans — registrado no audit_log imutavel.
LAB_ONLY=true
# Lista separada por virgula OU JSON array. Hostnames, IPs, CIDRs, *.dominio.
TARGET_ALLOWLIST=juice-shop,dvwa,webgoat,localhost,127.0.0.1,10.0.0.0/8
REQUIRE_AUTH_REF=false

# --- Reports ---
REPORTS_DIR=./reports
